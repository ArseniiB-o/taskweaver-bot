# Required ----------------------------------------------------------------

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter API Key (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional ----------------------------------------------------------------

# OpenRouter model id
OPENROUTER_MODEL=google/gemini-2.5-flash

# Comma-separated Telegram user IDs that may use the bot.
# IMPORTANT: leaving this EMPTY makes the bot public — every user can drive
# the executor and rack up your OpenRouter bill. Set it.
ALLOWED_USERS=

# Per-file size cap in MB (default 50, max 2000)
MAX_FILE_SIZE_MB=50

# Cap on number of files per request (default 10)
MAX_FILES_PER_REQUEST=10

# Working directory for downloads / per-job temp dirs (default: OS tmpdir)
TEMP_DIR=

# Per-user rate limit (token bucket)
RATE_CAPACITY=10
RATE_REFILL_PER_MINUTE=20
MAX_CONCURRENT_PER_USER=1

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Allow downloads / requests to private/internal IPs (default false).
# Only enable in air-gapped or test environments.
ALLOW_PRIVATE_URLS=false
